# whatismyip environment configuration
# Copy this file to .env and fill in values for local development.
# In production (OpenShift, Docker, etc.) inject these as environment variables.
#
# Flask picks up variables prefixed with FLASK_ automatically via
# app.config.from_prefixed_env() — the prefix is stripped when stored in app.config.

# ── Core Flask settings ───────────────────────────────────────────────────────

# Generate a strong random key for production:  python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=change-me-in-production

# Bind host and port for the Flask dev server.
# Use FLASK_RUN_HOST=:: to accept both IPv4 and IPv6 connections (required for
# dual-stack simulation with CLIENT_ADDRESS_V4 / CLIENT_ADDRESS_V6 below).
# On macOS, port 5000 is claimed by AirPlay Receiver — use 5001 instead.
FLASK_RUN_HOST=127.0.0.1
FLASK_RUN_PORT=5000
# FLASK_RUN_HOST=::      # enable for dual-stack simulation
# FLASK_RUN_PORT=5001    # use if port 5000 is taken by AirPlay (macOS)

# Primary public URL for the site (used in canonical tags, JSON-LD, redirects)
FLASK_SERVER_URL=http://127.0.0.1:5000

# Separate IPv4 and IPv6 hostnames (used for dual-stack IP detection).
# The JS client fetches both to determine which address family is in use.
# For dual-stack simulation set FLASK_RUN_HOST=:: and point each URL to the
# appropriate loopback address so hostinfo calls arrive on different IP families.
# Leave FLASK_IPV6_SERVER_URL empty to disable dual-stack detection.
FLASK_IPV4_SERVER_URL=http://127.0.0.1:5000
FLASK_IPV6_SERVER_URL=
# FLASK_IPV6_SERVER_URL=http://[::1]:5000   # enable for dual-stack simulation

# ── Infoblox IPAM (optional) ──────────────────────────────────────────────────
# Enables network/VLAN details, DHCP info, and address records for campus IPs.
# Without these, campus IP lookup is skipped and no network details are shown.

FLASK_IB_SERVER=ipam.example.edu
FLASK_IB_USERNAME=readonly_api_user
FLASK_IB_PASSWORD=

# ── Extreme Networks XMC / ExtremeCloud IQ Site Engine (optional) ─────────────
# Enables NAC endpoint details: switch port, VLAN, policy, and connection type.
# Without these, the NAC section is omitted for campus devices.

FLASK_XMC_SERVER=xmc.example.edu
FLASK_XMC_CLIENT_ID=
FLASK_XMC_SECRET=

# ── Network Information Tool / Building API (optional) ────────────────────────
# Enables building name and location lookup for wired campus connections.
# This is a UNC-specific internal API — replace with your own or leave blank.
# Without these, building details are omitted from wired connection results.

FLASK_NIT_SERVER=
FLASK_NIT_AUTH=

# ── Cisco Meraki (optional) ───────────────────────────────────────────────────
# Enables AP name, building lookup, and client details for Meraki wireless clients.
# Without these, Meraki clients show MAC and SSID only (no AP name or building).

FLASK_MERAKI_API_KEY=
FLASK_MERAKI_ORG_ID=

# ── Google Maps (optional) ────────────────────────────────────────────────────
# Enables an embedded map showing building location for wired campus connections.
# Requires FLASK_NIT_SERVER to be configured. Leave blank to hide the map.

FLASK_GOOGLE_MAPS_API_KEY=

# ── Metrics dashboard ─────────────────────────────────────────────────────────
# Basic auth credentials for the /metrics page.
# Leave both blank to make the metrics page publicly accessible.

FLASK_METRICS_USERNAME=
FLASK_METRICS_PASSWORD=

# ── Local dev address simulation (never set in production) ────────────────────
# Override the detected client IP without needing real campus network access.
#
# Single-address: overrides both IPv4 and IPv6 hostinfo slots.
#CLIENT_ADDRESS=152.2.0.1
#
# Dual-stack: override each slot independently.
# Requires FLASK_IPV4_SERVER_URL=http://127.0.0.1:5000 (IPv4 loopback) and
# FLASK_IPV6_SERVER_URL=http://[::1]:5000 (IPv6 loopback) so the two hostinfo
# calls arrive on different connection families.
#CLIENT_ADDRESS_V4=152.2.0.1
#CLIENT_ADDRESS_V6=2610:28:3091:1000:2::1
#
# Simulate a forwarded/proxy header:
#FORWARDED_FOR=203.0.113.5
